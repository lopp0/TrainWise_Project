# Copy this file to `.env` (which is gitignored) and fill in real values.
# NEVER commit real keys. The values below are placeholders.

# OpenAI key for the in-app AI chat + injury advice (bundled into the APK via
# the EXPO_PUBLIC_ prefix; use a restricted/limited key, do not distribute the APK).
EXPO_PUBLIC_OPENAI_API_KEY=your-openai-key-here

# Google API key used by the Maps SDK (native) AND the Weather / Air Quality /
# Places REST calls. Injected into the native build by app.config.js, so it is
# never written into app.json. RESTRICT it in Google Cloud (Android package +
# SHA-1, and limit to the specific APIs).
GOOGLE_MAPS_API_KEY=your-restricted-google-maps-key
